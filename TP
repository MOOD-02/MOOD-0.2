-- ตัวแปรควบคุม
local active = false
local pullThread = nil
local myHRP = nil

-- อัปเดตตำแหน่งตัวเอง
local function updateMyPosition()
    local char = waitForCharacter()
    myHRP = char and char:FindFirstChild("HumanoidRootPart")
    return myHRP
end

-- ฟังก์ชันดึงผู้เล่น
local function pullPlayer(target)
    if not target or not target.Character then return false end
    
    local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
    if not targetHRP then return false end
    
    if not myHRP then
        updateMyPosition()
        if not myHRP then return false end
    end
    
    local pullPos = myHRP.Position + (myHRP.CFrame.LookVector * 3) + Vector3.new(0, 2, 0)
    
    local success = pcall(function()
        targetHRP.CFrame = CFrame.new(pullPos)
        targetHRP.Velocity = Vector3.new(0, 0, 0)
        targetHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    end)
    
    return success
end

-- ดึงทุกคน
local function pullAll()
    local count = 0
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= lp then
            if pullPlayer(player) then
                count = count + 1
            end
        end
    end
    return count
end

-- ลูปหลัก
local function startPullLoop()
    while active do
        updateMyPosition()
        local pulled = pullAll()
        if pulled > 0 then
            Status.Text = "▸ STATUS: PULLING " .. pulled .. " PLAYERS ◂"
            Status.TextColor3 = Color3.fromRGB(255, 255, 255)
        end
        task.wait(0.3)
    end
end

-- เมื่อ Character เปลี่ยน
lp.CharacterAdded:Connect(function()
    task.wait(0.5)
    updateMyPosition()
    if active then
        Status.Text = "▸ STATUS: RESPAWNED ◂"
    end
end)

-- ปุ่มเปิด/ปิด
ToggleBtn.MouseButton1Click:Connect(function()
    active = not active
    
    if active then
        updateMyPosition()
        if not myHRP then
            Status.Text = "▸ STATUS: LOADING... ◂"
            task.wait(1)
            updateMyPosition()
        end
        
        ToggleBtn.Text = "🔴 CLOSE 🔴"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        Status.Text = "▸ STATUS: ACTIVE ◂"
        Status.TextColor3 = Color3.fromRGB(255, 255, 255)
        
        pullThread = coroutine.create(startPullLoop)
        coroutine.resume(pullThread)
    else
        ToggleBtn.Text = "⚡ OPEN ⚡"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        Status.Text = "▸ STATUS: OFFLINE ◂"
        Status.TextColor3 = Color3.fromRGB(150, 150, 150)
    end
end)

