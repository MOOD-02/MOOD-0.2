-- ==================== FLING แรงสุด (เน้นตกดิน) ====================
local hiddenfling = false
local flingThread

local function SuperFling()
    while hiddenfling do
        RunService.Heartbeat:Wait()
        
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        
        if hrp then
            local oldVel = hrp.Velocity
            
            -- แรงตกดินสุด ๆ (ตามที่ขอ)
            hrp.Velocity = oldVel * 1e8 + Vector3.new(0, -250000000, 0)   -- ตกหนักมาก
            hrp.AssemblyLinearVelocity = oldVel * 1e8 + Vector3.new(0, -350000000, 0)
            
            RunService.RenderStepped:Wait()
            
            hrp.Velocity = Vector3.new(oldVel.X * 0.2, -800, oldVel.Z * 0.2)
            hrp.AssemblyLinearVelocity = Vector3.new(oldVel.X * 0.2, -1200, oldVel.Z * 0.2)
            
            RunService.Stepped:Wait()
            
            hrp.Velocity = Vector3.new(0, -1500, 0)   -- กระแทกพื้นแรง
            hrp.AssemblyLinearVelocity = Vector3.new(0, -2000, 0)
        end
    end
end

-- ==================== Toggle ====================
ToggleButton.MouseButton1Click:Connect(function()
    PlayClickAnimation()
    
    hiddenfling = not hiddenfling
    
    if hiddenfling then
        ToggleButton.Text = "DEACTIVATE"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(80, 0, 0)
        WingsFlap(true)
        
        flingThread = coroutine.create(SuperFling)
        coroutine.resume(flingThread)
        
    else
        ToggleButton.Text = "ACTIVATE FLING"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        WingsFlap(false)
        hiddenfling = false
    end
end)

