local function PlayClickAnimation()
    TweenService:Create(ToggleButton, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), 
        {Size = UDim2.new(0, 190, 0, 46)}):Play()
    task.wait(0.1)
    TweenService:Create(ToggleButton, TweenInfo.new(0.15, Enum.EasingStyle.Bounce), 
        {Size = UDim2.new(0, 200, 0, 50)}):Play()
end

local function WingsFlap(active)
    if active then
        TweenService:Create(Wings, TweenInfo.new(0.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), 
            {Rotation = 15, ImageTransparency = 0.2}):Play()
    else
        Wings.Rotation = 0
        Wings.ImageTransparency = 0
    end
end

