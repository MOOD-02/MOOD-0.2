local function StopPhysics(hrp)

    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero

    hrp.Velocity = Vector3.zero
    hrp.RotVelocity = Vector3.zero

    for _, v in ipairs(hrp:GetChildren()) do

        if v:IsA("BodyVelocity")
        or v:IsA("BodyAngularVelocity")
        or v:IsA("LinearVelocity")
        or v:IsA("AngularVelocity")
        or v:IsA("VectorForce")
        or v:IsA("BodyForce")
        or v:IsA("RocketPropulsion") then

            v:Destroy()
        end
    end
end

local function ReturnSafe(hrp)

    if LastSafeCFrame then

        hrp.Anchored = true

        StopPhysics(hrp)

        hrp.CFrame = LastSafeCFrame

        task.wait(0.15)

        StopPhysics(hrp)

        hrp.Anchored = false
    end
end

