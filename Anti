local PhysicsService = game:GetService("PhysicsService")

local LocalPlayer = Players.LocalPlayer

local Counter = {
    Enabled = false
}

local Connection = nil

local function ForceEnableCollision()
    local char = LocalPlayer.Character
    if not char then return end
    
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = true
            part.CustomPhysicalProperties = PhysicalProperties.new(
                1.5,     -- Density สูงขึ้นนิด
                0.7,     -- Friction
                0.5,     -- Elasticity
                1,       -- Weight
                1
            )
        end
    end
end

local function ResetCollisionGroup()
    pcall(function()
        -- บังคับให้ตัวเรา collision กับทุกกลุ่ม
        PhysicsService:CollisionGroupSetCollidable("Players", "Players", true)
    end)
end

local function CounterFling()
    if not Counter.Enabled then return end
    
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    local root = char.HumanoidRootPart
    
    -- 1. บังคับ CanCollide
    ForceEnableCollision()
    
    -- 2. Reset Collision Group
    ResetCollisionGroup()
    
    -- 3. ป้องกันและแก้ไข Velocity (สำคัญมาก)
    if root.Velocity.Magnitude > 80 then
        local vel = root.Velocity
        root.Velocity = Vector3.new(vel.X * 0.4, vel.Y, vel.Z * 0.4) -- ลดแรง fling แต่ยังคงแรงกระแทก
    end
    
    -- 4. ทำให้ตัวเอง "หนัก" ชั่วคราวเพื่อส่งแรงกระแทกดีขึ้น
    root.AssemblyLinearVelocity = root.AssemblyLinearVelocity
end

-- เริ่มทำงาน
local function Start()
    if Connection then return end
    Connection = RunService.Heartbeat:Connect(CounterFling)
    print("Anti Anti-Fling ทำงาน (Force Collision + Velocity Fix)")
end

local function Stop()
    if Connection then
        Connection:Disconnect()
        Connection = nil
    end
end

