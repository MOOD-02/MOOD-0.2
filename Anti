--========================
-- MAIN LOOP
--========================

RunService.Heartbeat:Connect(function()

    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")

    if not hrp then
        return
    end

    --========================
    -- ANTI FLING
    --========================

    if AntiFling then

        if hrp.Velocity.Magnitude > 120 then

            SetStatus("⚠️ Fling Detected")

            ReturnSafe(hrp)
        end
    end

    --========================
    -- ANTI BRING
    --========================

    if AntiBring and LastPosition then

        local dist =
            (hrp.Position - LastPosition).Magnitude

        if dist > 25 then

            SetStatus("⚠️ Bring Detected")

            ReturnSafe(hrp)
        end
    end

    --========================
    -- ANTI VELOCITY
    --========================

    if AntiVelocity then

        if hrp.Velocity.Magnitude > 70 then

            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero

            SetStatus("⚠️ Velocity Removed")
        end
    end

    --========================
    -- ANTI PHYSICS
    --========================

    if AntiPhysics then

        StopPhysics(hrp)
    end

    --========================
    -- ANTI SUSPICIOUS
    --========================

    if AntiSuspicious then

        for _, plr in ipairs(Players:GetPlayers()) do

            if plr ~= lp then

                local tchar = plr.Character
                local thrp = tchar and tchar:FindFirstChild("HumanoidRootPart")

                if thrp then

                    local dist =
                        (thrp.Position - hrp.Position).Magnitude

                    local speed =
                        thrp.Velocity.Magnitude

                    if dist < 10 and speed > 80 then

                        SetStatus("⚠️ Suspicious Player")

                        ReturnSafe(hrp)
                    end
                end
            end
        end
    end
end)
